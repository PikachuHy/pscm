(define (try-load path)
  (display "Loading ") (display path) (newline)
  (catch #t
    (lambda () (load path) (display "  OK") (newline))
    (lambda (key . args)
      (display "  ERROR: ") (display key)
      (display " ") (display args) (newline))))

